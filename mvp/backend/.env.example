PORT=5000
DATABASE_URL=postgres://user:password@localhost:5432/onthemove
REDIS_URL=redis://localhost:6379
JWT_SECRET=your_jwt_secret_here

# Payment Mode: 'paybill' or 'daraja'
PAYMENT_MODE=paybill
PAYBILL_NUMBER=247247
PAYBILL_ACCOUNT_PREFIX=ONTHEMOVE

# M-Pesa Daraja API Settings
MPESA_CONSUMER_KEY=your_mpesa_key
MPESA_CONSUMER_SECRET=your_mpesa_secret
MPESA_SHORTCODE=your_mpesa_shortcode
MPESA_PASSKEY=your_mpesa_passkey
MPESA_CALLBACK_URL=https://yourdomain.com/api/v1/payments/callback

# Africa's Talking SMS Settings
AFRICASTALKING_USERNAME=your_username
AFRICASTALKING_API_KEY=your_api_key
